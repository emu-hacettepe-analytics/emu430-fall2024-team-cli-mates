## 1. Introduction & Data Overview

Climate change is no longer a future projection but a present reality for Turkey. Positioned in the Mediterranean basin, the country faces unique vulnerabilities. This Exploratory Data Analysis (EDA) aims to quantify the environmental shifts and their correlation with agricultural output.

The Dataset
The analysis integrates three primary data streams:

Thermal Data (T2M): Average temperature at 2 meters above the earth's surface (ÂḞC).

Hydrological Data (PRECTOTCORR): Corrected precipitation amounts (mm/day).

Agricultural Value: The monetary value of crop production (Thousand TL) at the provincial level, aggregated into regional totals.

The data was wrangled to ensure temporal consistency and spatial alignment, transforming raw provincial Excel files and regional CSVs into a "Tidy Data" format for robust visualization.

 
#### 2. Hydrological Shifts: Precipitation Volatility
While temperature shows a steady climb, precipitation is characterized by its unpredictability. For an agrarian economy, the distribution of water is as critical as the total amount.
```{r}
#| label: turkiye-bolgeler-sicaklik
#| message: false

#| label: turkiye-tum-bolgeler-yagis
#| message: false
#| warning: false

library(tidyverse)


marmara_pr <- read_csv("data/marmara_precipitaion2000-2025.csv", skip = 9) %>% mutate(Region = "Marmara")
ic_anadolu_pr <- read_csv("data/iÃ§anadolu_precipitaion.csv", skip = 9) %>% mutate(Region = "ÄḞÃ§ Anadolu")
akdeniz_pr <- read_csv("data/akdeniz_precipitation.csv", skip = 9) %>% mutate(Region = "Akdeniz")
dogu_anadolu_pr <- read_csv("data/doguanadolu_precipitation.csv", skip = 9) %>% mutate(Region = "DoÄu Anadolu")
ege_pr <- read_csv("data/egebÃ¶lgesi_precipitaion_average2000-2025.csv", skip = 9) %>% mutate(Region = "Ege")
guneydogu_anadolu_pr <- read_csv("data/guneydoguanadolu_precipitation.csv", skip = 9) %>% mutate(Region = "GÃỳneydoÄu Anadolu")
karadeniz_pr <- read_csv("data/karadeniz_precipitation.csv", skip = 9) %>% mutate(Region = "Karadeniz")


turkiye_precip_all <- bind_rows(
  marmara_pr, ic_anadolu_pr, akdeniz_pr, dogu_anadolu_pr,
  ege_pr, guneydogu_anadolu_pr, karadeniz_pr
)


turkiye_bolge_yagis <- turkiye_precip_all %>%
  group_by(YEAR, Region) %>%
  summarise(Bolge_Ortalama_Yagis = mean(ANN, na.rm = TRUE), .groups = "drop")


ggplot(turkiye_bolge_yagis, aes(x = YEAR, y = Bolge_Ortalama_Yagis, fill = Region)) +
  geom_bar(stat = "identity", alpha = 0.7) + 
  geom_smooth(method = "lm", color = "darkblue", se = FALSE, linetype = "solid", size = 0.8) + 
  facet_wrap(~ Region, ncol = 3) + 
  labs(
    title = "TÃỳrkiye'nin 7 BÃ¶lgesinde YÄḟllÄḟk Ortalama YaÄÄḟÅ MiktarÄḟ (2000-2025)",
    subtitle = "Renkli sÃỳtunlar yÄḟllÄḟk ortalamayÄḟ, koyu mavi Ã§izgi ise genel yaÄÄḟÅ eÄilimini gÃ¶sterir",
    x = "YÄḟl",
    y = "Ortalama YaÄÄḟÅ (mm/gÃỳn)"
  ) +
  theme_minimal() +
  theme(
    legend.position = "none", 
    strip.text = element_text(size = 11, face = "bold"),
    axis.text.x = element_text(angle = 45, hjust = 1)
  )
```
Analysis of Water Stress
The Black Sea region remains the outlier with high and relatively stable precipitation. However, the Aegean and Central Anatolia regionsâTurkey's primary grain and fruit basketsâshow concerning levels of volatility. The downward or stagnant trend lines in these regions, combined with rising temperatures, indicate a high risk of "evapotranspiration," where plants lose moisture faster than the soil can replenish it.


Next stage of our EDA explores how the economic value of crops has changed alongside these climatic shifts.
```{r}


#| code-fold: true
#| code-summary: "Veri YÃỳkleme ve BirleÅtirme AdÄḟmlarÄḟ"
#| label: turkiye-7-bolge-sicaklik
#| message: false
#| warning: false

library(tidyverse)

# Fonksiyon: DosyayÄḟ oku, ilk 9 satÄḟrÄḟ atla ve bÃ¶lge ismi ekle
read_region <- function(file_path, region_name) {
  read_csv(file_path, skip = 9) %>%
    mutate(Region = region_name)
}

# TÃỳm sÄḟcaklÄḟk dosyalarÄḟnÄḟ oku ve birleÅtir
turkiye_temp <- bind_rows(
  read_region("data/akdeniz_T2M.csv", "Akdeniz"),
  read_region("data/doguanadolu_T2M.csv", "DoÄu Anadolu"),
  read_region("data/ege_bÃ¶lgesi_temperatureat2metersrange_2000-2025.csv", "Ege"),
  read_region("data/guneydoguanadolu_tT2M.csv", "GÃỳneydoÄu Anadolu"),
  read_region("data/iÃ§anadolu_T2M.csv", "ÄḞÃ§ Anadolu"),
  read_region("data/karadeniz_T2M.csv", "Karadeniz"),
  read_region("data/marmara_T2M_2000-2025.csv", "Marmara")
)

# BÃ¶lge bazlÄḟ yÄḟllÄḟk sÄḟcaklÄḟk Ã¶zeti
turkiye_bolge_ozet <- turkiye_temp %>%
  group_by(YEAR, Region) %>%
  summarise(Bolge_Ortalama_Sicaklik = mean(ANN, na.rm = TRUE), .groups = "drop")

# Grafik: 7 BÃ¶lge Yan Yana
ggplot(turkiye_bolge_ozet, aes(x = YEAR, y = Bolge_Ortalama_Sicaklik, color = Region)) +
  geom_line(linewidth = 1) + # 'size' yerine 'linewidth' gÃỳncel sÃỳrÃỳmler iÃ§in daha iyidir
  geom_smooth(method = "lm", color = "black", linetype = "dashed", linewidth = 0.5) +
  facet_wrap(~ Region, ncol = 3) + 
  labs(
    title = "TÃỳrkiye'nin 7 BÃ¶lgesinde YÄḟllÄḟk Ortalama SÄḟcaklÄḟk DeÄiÅimi (2000-2025)",
    x = "YÄḟl",
    y = "SÄḟcaklÄḟk (ÂḞC)"
  ) +
  theme_minimal() +
  theme(
    legend.position = "none", 
    strip.text = element_text(size = 11, face = "bold"),
    axis.text.x = element_text(angle = 45, hjust = 1) 
  ) # <-- Eksik olan parantez burasÄḟydÄḟ, eklendi.
```
```{r}



library(readxl)
library(ggplot2)
library(scales)

# Excel dosyasÄḟndan sadece verilerin olduÄu C5:D31 aralÄḟÄÄḟnÄḟ okuyoruz.
# col_names ile sÃỳtunlara kendimiz isim veriyoruz ki iÅimiz kolaylaÅsÄḟn.
veri <- read_excel("data/uretim_turkiye.xlsx", 
                   range = "C5:D31", 
                   col_names = c("Yil", "Uretim_Degeri"))

# Excel'de metin olarak algÄḟlanan yÄḟllarÄḟ ve Ãỳretim deÄerlerini sayÄḟya Ã§eviriyoruz
veri$Yil <- as.numeric(veri$Yil)
veri$Uretim_Degeri <- as.numeric(veri$Uretim_Degeri)

# ggplot2 ile zaman serisi Ã§izgi grafiÄini oluÅturuyoruz
ggplot(veri, aes(x = Yil, y = Uretim_Degeri)) +
  geom_line(color = "#2c3e50", linewidth = 1.2) +    
  geom_point(color = "#e74c3c", size = 2.5) +        
  labs(
    title = "TÃỳrkiye Bitkisel Ãretim DeÄeri (1995 - 2021)",
    subtitle = "YÄḟllara GÃ¶re Ãretim DeÄiÅimi",
    x = "YÄḟl",
    y = "Bitkisel Ãretim DeÄeri (Bin TL)"
  ) +
  scale_x_continuous(breaks = seq(min(veri$Yil), max(veri$Yil), by = 2)) +
  scale_y_continuous(labels = comma_format(big.mark = ".", decimal.mark = ",")) +
  theme_minimal() +
  theme(
    plot.title = element_text(face = "bold", size = 14),
    axis.text.x = element_text(angle = 45, hjust = 1) 
  )
```


The nominal value of agricultural production has grown exponentially, especially in the Mediterranean and Aegean regions. While this appears positive, it must be viewed with caution. This rise is likely influenced by inflation and the shift toward high-value, export-oriented greenhouse crops. The divergence between "rising value" and "deteriorating climate conditions" suggests that Turkish agriculture is becoming increasingly capital-intensive, requiring more investment in irrigation and fertilizers to combat climate stress.
```{r}

# Gerekli kÃỳtÃỳphaneler
library(readxl)
library(dplyr)
library(ggplot2)
library(scales)

# 1. Ãretim verisini okuma
veri <- read_excel("data/uretim_turkiye.xlsx", 
                   range = "C5:D31", 
                   col_names = c("Yil", "Uretim_Degeri"))

veri$Yil <- as.numeric(veri$Yil)
veri$Uretim_Degeri <- as.numeric(veri$Uretim_Degeri)

# 2. Enflasyon verisini okuma 
# DÄḞKKAT 1: read_csv YERÄḞNE read_excel KULLANIYORUZ!
# DÄḞKKAT 2: read_excel isimsiz sÃỳtunlara ...1, ...2, ...3 isimlerini verir.
tufe_raw <- suppressMessages(read_excel("data/enflasyon.xlsx", 
                                        col_names = FALSE, 
                                        n_max = 24))

# ÄḞlk sÃỳtunu YÄḟl olan satÄḟrlarÄḟ alÄḟp aylarÄḟ (...2 ile ...13 arasÄḟ) seÃ§iyoruz
tufe_df <- tufe_raw %>%
  mutate(Yil = suppressWarnings(as.numeric(...1))) %>%
  filter(!is.na(Yil)) %>%
  select(Yil, ...2:...13) %>%
  distinct(Yil, .keep_all = TRUE) # Ãift okuma ihtimaline karÅÄḟ sadece gerÃ§ek endeksi tut

# AylÄḟk endeks deÄerlerini sayÄḟsal tipe Ã§evirme
tufe_df[, 2:13] <- lapply(tufe_df[, 2:13], function(x) suppressWarnings(as.numeric(x)))

# YÄḟllÄḟk ortalama TÃFE endeksini hesaplÄḟyoruz (12 ayÄḟn ortalamasÄḟ)
tufe_df$Yillik_Tufe <- rowMeans(tufe_df[, 2:13], na.rm = TRUE)

# Sadece YÄḟl ve YÄḟllÄḟk Ortalama TÃFE'yi ayÄḟrÄḟyoruz
tufe_secili <- tufe_df %>% select(Yil, Yillik_Tufe)

# 3. Verileri BirleÅtirme ve Reel DeÄer Hesaplama
# Reel DeÄer = (Nominal DeÄer / YÄḟllÄḟk TÃFE Endeksi) * 100
birlesik_veri <- inner_join(veri, tufe_secili, by = "Yil") %>%
  mutate(Reel_Uretim_Degeri = (Uretim_Degeri / Yillik_Tufe) * 100)

# 4. Enflasyondan ArÄḟndÄḟrÄḟlmÄḟÅ GrafiÄi Ãizdirme
ggplot(birlesik_veri, aes(x = Yil, y = Reel_Uretim_Degeri)) +
  geom_line(color = "#2c3e50", linewidth = 1.2) +    
  geom_point(color = "#e74c3c", size = 2.5) +        
  labs(
    title = "TÃỳrkiye Bitkisel Ãretim DeÄeri (Enflasyondan ArÄḟndÄḟrÄḟlmÄḟÅ)",
    subtitle = "YÄḟllara GÃ¶re Reel Ãretim DeÄiÅimi (2003 = 100 BazlÄḟ Fiyatlarla)",
    x = "YÄḟl",
    y = "Reel Bitkisel Ãretim DeÄeri (Bin TL)"
  ) +
  scale_x_continuous(breaks = seq(min(birlesik_veri$Yil), max(birlesik_veri$Yil), by = 2)) +
  scale_y_continuous(labels = comma_format(big.mark = ".", decimal.mark = ",")) +
  theme_minimal() +
  theme(
    plot.title = element_text(face = "bold", size = 14),
    axis.text.x = element_text(angle = 45, hjust = 1) 
  )
```



```{r}


library(tidyverse)
library(readxl)
library(scales)
library(ggplot2)

# --- 1. YAÄIÅ VERÄḞSÄḞNÄḞN HAZIRLANMASI ---
# (Mevcut CSV dosyalarÄḟnÄḟn data klasÃ¶rÃỳnde olduÄu varsayÄḟlmaktadÄḟr)
marmara_pr <- read_csv("data/marmara_precipitaion2000-2025.csv", skip = 9) %>% mutate(Region = "Marmara")
ic_anadolu_pr <- read_csv("data/iÃ§anadolu_precipitaion.csv", skip = 9) %>% mutate(Region = "ÄḞÃ§ Anadolu")
akdeniz_pr <- read_csv("data/akdeniz_precipitation.csv", skip = 9) %>% mutate(Region = "Akdeniz")
dogu_anadolu_pr <- read_csv("data/doguanadolu_precipitation.csv", skip = 9) %>% mutate(Region = "DoÄu Anadolu")

turkiye_precip_all <- bind_rows(marmara_pr, ic_anadolu_pr, akdeniz_pr, dogu_anadolu_pr)

# YÄḟllÄḟk ortalama yaÄÄḟÅÄḟ hesaplÄḟyoruz
yagis_verisi <- turkiye_precip_all %>%
  group_by(YEAR) %>%
  summarise(Ortalama_Yagis = mean(ANN, na.rm = TRUE)) %>%
  rename(Yil = YEAR) # BirleÅtirme kolaylÄḟÄÄḟ iÃ§in sÃỳtun adÄḟnÄḟ "Yil" yapÄḟyoruz

# --- 2. ÃRETÄḞM VERÄḞSÄḞNÄḞN HAZIRLANMASI ---
# (uretim_turkiye.xlsx dosyasÄḟnÄḟn data klasÃ¶rÃỳnde olduÄu varsayÄḟlmaktadÄḟr)
uretim_verisi <- read_excel("data/uretim_turkiye.xlsx", 
                            range = "C5:D31", 
                            col_names = c("Yil", "Uretim_Degeri"))

uretim_verisi$Yil <- as.numeric(uretim_verisi$Yil)
uretim_verisi$Uretim_Degeri <- as.numeric(uretim_verisi$Uretim_Degeri)

# --- 3. VERÄḞLERÄḞ BÄḞRLEÅTÄḞRME (Sadece ortak yÄḟllar) ---
# inner_join sadece her iki veri setinde de olan yÄḟllarÄḟ korur (Ãrn: 2000-2021 arasÄḟ)
birlesik_veri <- inner_join(yagis_verisi, uretim_verisi, by = "Yil")

# --- 4. KORELASYON GRAFÄḞÄÄḞ (Scatter Plot) ---
# Korelasyon katsayÄḟsÄḟnÄḟ hesaplayÄḟp grafiÄe ekleyebiliriz (isteÄe baÄlÄḟ ama gÃỳzel durur)
korelasyon <- cor(birlesik_veri$Ortalama_Yagis, birlesik_veri$Uretim_Degeri, use = "complete.obs")

ggplot(birlesik_veri, aes(x = Ortalama_Yagis, y = Uretim_Degeri)) +
  geom_point(color = "#e74c3c", size = 3) + 
  # Trend Ã§izgisi ekliyoruz (doÄrusal iliÅkiyi gÃ¶rmek iÃ§in)
  geom_smooth(method = "lm", color = "#2c3e50", se = TRUE, fill = "lightblue", alpha = 0.5) + 
  labs(
    title = "TÃỳrkiye: YaÄÄḟÅ MiktarÄḟ ile Bitkisel Ãretim DeÄeri ÄḞliÅkisi",
    subtitle = paste("Sadece Ortak YÄḟllar (", min(birlesik_veri$Yil), " - ", max(birlesik_veri$Yil), ") | Korelasyon (r): ", round(korelasyon, 2), sep=""),
    x = "Ortalama YaÄÄḟÅ (mm/gÃỳn)",
    y = "Bitkisel Ãretim DeÄeri (Bin TL)"
  ) +
  # Ãretim deÄeri bÃỳyÃỳk sayÄḟlar olduÄu iÃ§in okunabilirliÄi artÄḟrÄḟyoruz
  scale_y_continuous(labels = comma_format(big.mark = ".", decimal.mark = ",")) +
  theme_minimal() +
  theme(
    plot.title = element_text(face = "bold", size = 14)
  )
```

```{r}




library(tidyverse)
library(readxl)
library(scales)

# --- 1. BÄḞTKÄḞSEL ÃRETÄḞM VERÄḞSÄḞ ---
# Veriyi okuyup yÄḟllar ve deÄerleri sayÄḟsal formata Ã§eviriyoruz
uretim_veri <- read_excel("data/uretim_turkiye.xlsx", 
                          range = "C5:D31", 
                          col_names = c("Yil", "Uretim_Degeri")) %>%
  mutate(
    Yil = as.numeric(Yil),
    Uretim_Degeri = as.numeric(Uretim_Degeri)
  )

# --- 2. TARIM ALANLARI VERÄḞSÄḞ ---
# Veriyi okuyup temizliyoruz
alan_veri <- read_excel("data/tarimurunualanlar.xlsx", skip = 3)
colnames(alan_veri) <- c("Ana_Kategori", "Alan_Turu", "Yil", "Alan")

temiz_alan_veri <- alan_veri %>%
  fill(Alan_Turu, .direction = "down") %>% 
  filter(!is.na(Yil)) %>%
  mutate(
    Yil = as.numeric(Yil),
    Alan = as.numeric(Alan)
  ) %>%
  # ÃNEMLÄḞ: Ãretim verisi TÃỳrkiye geneli toplam olduÄu iÃ§in,
  # o yÄḟla ait tÃỳm farklÄḟ alan tÃỳrlerini (meyve, sebze, tahÄḟl vb.) topluyoruz.
  group_by(Yil) %>%
  summarise(Toplam_Alan = sum(Alan, na.rm = TRUE))

# --- 3. VERÄḞLERÄḞ BÄḞRLEÅTÄḞRME VE ORANLAMA ---
# Sadece iki dosyada da olan (ortak) yÄḟllarÄḟ birleÅtiriyoruz
birlesik_veri <- inner_join(uretim_veri, temiz_alan_veri, by = "Yil") %>%
  mutate(
    # ÄḞsteÄin doÄrultusunda: Bitkisel Ãretim / TarÄḟm AlanÄḟ
    Birim_Alan_Degeri = Uretim_Degeri / Toplam_Alan
  )

# --- 4. GÃRSELLEÅTÄḞRME ---
ggplot(birlesik_veri, aes(x = Yil, y = Birim_Alan_Degeri)) +
  geom_line(color = "#8e44ad", linewidth = 1.2) + # Ãizgi rengi (Mor tonlarÄḟnda)
  geom_point(color = "#2c3e50", size = 3) +       # Nokta rengi
  # Genel trendi gÃ¶rmek iÃ§in istersen aÅaÄÄḟdaki satÄḟrÄḟn baÅÄḟndaki '#' iÅaretini kaldÄḟrabilirsin
  # geom_smooth(method = "lm", color = "gray50", linetype = "dashed", se = FALSE) +
  labs(
    title = "TÃỳrkiye: Birim TarÄḟm AlanÄḟ BaÅÄḟna Ãretim DeÄeri",
    subtitle = "Hesaplama: Toplam Bitkisel Ãretim DeÄeri / Toplam TarÄḟm AlanÄḟ",
    x = "YÄḟl",
    y = "Birim Alan DeÄeri (Bin TL / Dekar)"
  ) +
  scale_x_continuous(breaks = seq(min(birlesik_veri$Yil), max(birlesik_veri$Yil), by = 2)) +
  scale_y_continuous(labels = comma_format(big.mark = ".", decimal.mark = ",")) +
  theme_minimal() +
  theme(
    plot.title = element_text(face = "bold", size = 14),
    axis.text.x = element_text(angle = 45, hjust = 1)
  )
```
```{r}



#| label: bolgesel-tarim-analizi
#| message: false
#| warning: false


library(readxl)   # Excel okumak iÃ§in tek Ã§Ã¶zÃỳm budur
library(tidyverse)
library(scales)

yol <- "data/uretim_il.xlsx"
df <- read_excel(yol, col_names = FALSE)


sehirler <- as.character(df[2, 4:ncol(df)])

# Veri 3. satÄḟrdan baÅlÄḟyor. 3. sÃỳtun YIL, 4. sÃỳtun ve sonrasÄḟ ÅEHÄḞR DEÄERLERÄḞ
ham_veri <- df[3:nrow(df), 3:ncol(df)]
colnames(ham_veri) <- c("Yil", sehirler)

# 4. TEMÄḞZLE VE UZUN FORMATA ÃEVÄḞR
uzun_veri <- ham_veri %>%
  mutate(Yil = as.numeric(Yil)) %>%
  filter(!is.na(Yil)) %>% # YÄḟl olmayan satÄḟrlarÄḟ at
  pivot_longer(
    cols = -Yil, 
    names_to = "Il", 
    values_to = "Uretim_Degeri"
  ) %>%
  mutate(
    Uretim_Degeri = as.numeric(Uretim_Degeri),
    # "Adana-1" gibi isimleri sadece "Adana" yapÄḟyoruz
    Il = trimws(gsub("-[0-9]+", "", Il)) 
  ) %>%
  filter(!is.na(Uretim_Degeri))
# 5. BÃLGE EÅLEÅTÄḞRMESÄḞ (SayÄḟlar eÅitlendi: Toplam 83 satÄḟr)
bolge_haritasi <- data.frame(
  Il = c(
    # Marmara (11 isim)
    "Edirne", "KÄḟrklareli", "TekirdaÄ", "ÄḞstanbul", "Kocaeli", "Yalova", "Sakarya", "Bilecik", "Bursa", "BalÄḟkesir", "Ãanakkale",
    # Ege (9 isim)
    "ÄḞzmir", "Manisa", "AydÄḟn", "Denizli", "MuÄla", "Afyonkarahisar", "Afyon", "KÃỳtahya", "UÅak",
    # Akdeniz (9 isim)
    "Antalya", "Burdur", "Isparta", "Mersin", "ÄḞÃ§el", "Adana", "Hatay", "Osmaniye", "KahramanmaraÅ",
    # ÄḞÃ§ Anadolu (13 isim)
    "Ankara", "Konya", "Karaman", "EskiÅehir", "Kayseri", "NevÅehir", "Yozgat", "Sivas", "KÄḟrÄḟkkale", "KÄḟrÅehir", "NiÄde", "Aksaray", "ÃankÄḟrÄḟ",
    # Karadeniz (18 isim)
    "Amasya", "Artvin", "BartÄḟn", "Bayburt", "Bolu", "Ãorum", "DÃỳzce", "Giresun", "GÃỳmÃỳÅhane", "KarabÃỳk", "Kastamonu", "Ordu", "Rize", "Samsun", "Sinop", "Tokat", "Trabzon", "Zonguldak",
    # DoÄu Anadolu (14 isim)
    "AÄrÄḟ", "Ardahan", "BingÃ¶l", "Bitlis", "ElazÄḟÄ", "Erzincan", "Erzurum", "Hakkari", "IÄdÄḟr", "Kars", "Malatya", "MuÅ", "Tunceli", "Van",
    # GÃỳneydoÄu Anadolu (9 isim)
    "AdÄḟyaman", "Batman", "DiyarbakÄḟr", "Gaziantep", "Kilis", "Mardin", "Siirt", "ÅanlÄḟurfa", "ÅÄḟrnak"
  ),
  Bolge = c(
    rep("Marmara", 11), 
    rep("Ege", 9),            # 10'dan 9'a dÃỳÅÃỳrdÃỳk
    rep("Akdeniz", 9), 
    rep("ÄḞÃ§ Anadolu", 13), 
    rep("Karadeniz", 18), 
    rep("DoÄu Anadolu", 14), 
    rep("GÃỳneydoÄu Anadolu", 9)
  )
)
bolge_ozet <- uzun_veri %>%
  left_join(bolge_haritasi, by = "Il") %>%
  filter(!is.na(Bolge)) %>%
  group_by(Yil, Bolge) %>%
  summarise(Toplam_Uretim = sum(Uretim_Degeri, na.rm = TRUE), .groups = "drop")

